# DATUM — photogrammetry pipeline backend
#
# Leave these UNSET for local development: the app falls back to the mock
# pipeline (procedural terrain + simulated progress) so it runs fully offline.
#
# Set them in production to wire the real WebODM backend. With VITE_PIPELINE_API
# present, no simulated data is used on the production path.

# WebODM instance base URL (no trailing slash)
VITE_PIPELINE_API=https://odm.example.com

# JWT token from POST /api/token-auth/
VITE_PIPELINE_TOKEN=

# WebODM project id that owns the reconstruction tasks
VITE_PIPELINE_PROJECT=1
